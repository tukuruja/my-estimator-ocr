# =====================================================================
# 建設統合見積システム 環境変数テンプレート
# このファイルをコピーして .env を作成してください
# cp .env.example .env
# .env は .gitignore に含まれています（絶対にgitにコミットしないこと）
# =====================================================================

# ─── サーバー設定 ───────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Gmail OAuth2 設定 ─────────────────────────────────────────────
# Google Cloud Console でOAuth2クライアントIDを取得してください
# https://console.cloud.google.com/apis/credentials
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=
# 見積依頼を受け取るGmailアドレス
GMAIL_TARGET_ADDRESS=merumaga.kensetusentai@gmail.com

# ─── Google Gemini API Key (推奨) ─────────────────────────────────
# Google Cloud Console > API キー から取得 (AIzaSy... 形式)
# OCR補完・見積ロジックAIにGemini 1.5 Flash/Proを使用
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# ─── OpenAI API Key (オプション / Geminiと排他) ───────────────────
# 設定した場合: GeminiよりOpenAI GPT-4.1-miniを優先使用
OPENAI_API_KEY=

# ─── OCR API URL ────────────────────────────────────────────────────
# 開発時: http://localhost:8000
# Docker起動時: http://ocr_api:8000 (docker-compose.ymlで自動設定)
OCR_API_URL=http://localhost:8000

# ─── Earthwork API URL (オプション) ────────────────────────────────
EARTHWORK_API_URL=http://localhost:8080

# ─── CORS設定 ───────────────────────────────────────────────────────
CORS_ALLOW_ORIGINS=http://localhost:3000,http://localhost:5173
