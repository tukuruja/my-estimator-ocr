{
  "skill_pack_name": "drawing_ocr_codex_skill_pack",
  "skill_version": "v1.0",
  "domain": "construction_drawing_ocr",
  "record_model": "knowledge_master + dictionaries + prompt_router + skill_modules",
  "objective": "建設業の図面を、媒体判定→表題欄抽出→シート分類→単位/縮尺/凡例解決→工種別抽出→図面間リンク→数量拾いマッピング→QAの順で読むためのCodexスキルパック",
  "global_policy": {
    "media_priority": [
      "ifc",
      "cad",
      "embedded_text_pdf",
      "vector_pdf",
      "raster_pdf",
      "image"
    ],
    "legend_priority": "図面固有凡例 > 標準辞書 > unknown",
    "document_priority": [
      "rfi",
      "site_explanation",
      "special_spec",
      "drawing",
      "standard_spec"
    ],
    "confidence_policy": {
      "auto_accept_min": 0.85,
      "needs_review_below": 0.75,
      "block_conditions": [
        "必須項目欠落",
        "主要シートの分類不明",
        "単位未解決",
        "高重要度conflict残存"
      ]
    }
  },
  "master_files": {
    "knowledge_master_csv": "drawing_ocr_knowledge_master.csv",
    "sheet_type_master_csv": "drawing_ocr_sheet_type_master.csv",
    "abbreviation_master_csv": "drawing_ocr_abbreviation_master.csv",
    "symbol_seed_master_csv": "drawing_ocr_symbol_seed_master.csv",
    "skill_import_csv": "drawing_ocr_skill_import.csv",
    "field_dictionary_csv": "drawing_ocr_field_dictionary.csv",
    "prompt_definitions_json": "drawing_ocr_prompt_definitions.json",
    "prompt_templates_md": "drawing_ocr_prompt_templates.md"
  },
  "input_contract": {
    "minimum_inputs": [
      "file_name",
      "mime_type",
      "page_count",
      "page_preview",
      "sheet_image"
    ],
    "optional_inputs": [
      "text_layer_probe",
      "vector_probe",
      "drawing_index",
      "spec_notes",
      "building_context"
    ]
  },
  "output_contract": {
    "minimum_outputs": [
      "drawing_no",
      "drawing_title",
      "sheet_type_id",
      "discipline",
      "review_queue",
      "acceptance_status"
    ],
    "trade_specific_outputs": [
      "rooms",
      "struct_members",
      "fixtures",
      "pipes",
      "alignment",
      "quantity_items"
    ]
  },
