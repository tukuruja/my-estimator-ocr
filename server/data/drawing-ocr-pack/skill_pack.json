  "prompts": [
    {
      "prompt_id": "PRM_001",
      "prompt_name": "媒体ルーター",
      "objective": "入力ファイルの媒体種別と最適処理経路を判定する",
      "when_to_run": "ページ読取の最初に実行"
    },
    {
      "prompt_id": "PRM_002",
      "prompt_name": "表題欄読取",
      "objective": "表題欄から図面メタデータを抽出する",
      "when_to_run": "媒体ルーティング後、シート単位で実行"
    },
    {
      "prompt_id": "PRM_003",
      "prompt_name": "シート分類",
      "objective": "図面のシート種別を分類する",
      "when_to_run": "表題欄読取の直後"
    },
    {
      "prompt_id": "PRM_004",
      "prompt_name": "単位・縮尺・方位解決",
      "objective": "単位・縮尺・方位・視点方向を解決する",
      "when_to_run": "シート分類後"
    },
    {
      "prompt_id": "PRM_005",
      "prompt_name": "凡例・略号解決",
      "objective": "凡例・略号・材料コードを正規化する",
      "when_to_run": "シート分類後、実体抽出前に実行"
    },
    {
      "prompt_id": "PRM_006",
      "prompt_name": "建築一般図抽出",
      "objective": "建築一般図から室・壁・建具・仕上を抽出する",
      "when_to_run": "sheet_typeが建築一般図のとき"
    },
    {
      "prompt_id": "PRM_007",
      "prompt_name": "構造図抽出",
      "objective": "構造図から基礎・配筋・部材・接合を抽出する",
      "when_to_run": "sheet_typeが構造図のとき"
    },
    {
      "prompt_id": "PRM_008",
      "prompt_name": "電気設備図抽出",
      "objective": "電気設備図から器具・盤・回路・弱電を抽出する",
      "when_to_run": "sheet_typeが電気設備図のとき"
    },
    {
      "prompt_id": "PRM_009",
      "prompt_name": "機械設備図抽出",
      "objective": "機械設備図から機器・配管・ダクト・衛生器具を抽出する",
      "when_to_run": "sheet_typeが機械設備図のとき"
    },
    {
      "prompt_id": "PRM_010",
      "prompt_name": "土木・道路図抽出",
      "objective": "道路・造成・外構図から線形・断面・排水・舗装を抽出する",
      "when_to_run": "sheet_typeが土木・道路・造成系のとき"
    },
    {
      "prompt_id": "PRM_011",
      "prompt_name": "改修・仮設解決",
      "objective": "既存/撤去/新設/復旧と仮設制約を解釈する",
      "when_to_run": "改修図・仮設図で実行"
    },
    {
      "prompt_id": "PRM_012",
      "prompt_name": "図面間リンク",
      "objective": "複数図面を通り芯・室・符号・系統で接続する",
      "when_to_run": "単票抽出の後に案件全体で実行"
    },
    {
      "prompt_id": "PRM_013",
      "prompt_name": "仕様優先順位解決",
      "objective": "図面・特記・標準仕様の優先順位で矛盾を解く",
      "when_to_run": "抽出後の仕様統合フェーズで実行"
    },
    {
      "prompt_id": "PRM_014",
      "prompt_name": "数量拾いマッピング",
      "objective": "抽出済み情報を数量拾い用の項目へ変換する",
      "when_to_run": "抽出・リンクの後で実行"
    },
    {
      "prompt_id": "PRM_015",
      "prompt_name": "QA・例外処理レビュー",
      "objective": "低信頼・矛盾・未知語をレビューキューへ整理する",
      "when_to_run": "全工程の最後に実行"
    }
  ],
