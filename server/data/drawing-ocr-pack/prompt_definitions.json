{
  "prompt_pack_name": "drawing_ocr_prompt_pack",
  "version": "v1.0",
  "prompts": [
    {
      "prompt_id": "PRM_001",
      "prompt_name": "媒体ルーター",
      "objective": "入力ファイルの媒体種別と最適処理経路を判定する",
      "when_to_run": "ページ読取の最初に実行",
      "required_inputs": [
        "file_name",
        "mime_type",
        "page_image_meta",
        "text_layer_probe",
        "vector_probe"
      ],
      "knowledge_filters": [
        "媒体ルーティング/前処理"
      ],
      "output_schema": {
        "source_media_type": "cad|ifc|vector_pdf|raster_pdf|image|unknown",
        "preferred_pipeline": "direct_text|vector_parse|ocr_cv|manual_review",
        "page_rotation_deg": "0|90|180|270",
        "sheet_split_required": "boolean",
        "preprocess_flags": [
          "deskew",
          "denoise",
          "binarize",
          "contrast_boost"
        ]
      },
      "system_rules": [
        "OCRは最後の手段。CAD/IFC/埋込テキストPDFを優先する。",
        "表題欄と凡例は全体読解の基点として先行抽出する。",
        "確信度が低い場合はunknownで返しmanual_reviewへ送る。"
      ],
      "failure_conditions": [
        "媒体種別確信度0.75未満",
        "表題欄候補0件かつ線分品質低い"
      ],
      "escalation_policy": {
        "route_on_fail": "manual_review",
        "queue": "ocr_router_review"
      },
      "prompt_template": "あなたは建設図面の媒体ルーターです。\n入力メタデータから、媒体種別、回転、分割要否、前処理フラグを判定してください。\n出力は必ずJSONのみ。\n入力:\n{{input_json}}\n"
    },
    {
      "prompt_id": "PRM_002",
      "prompt_name": "表題欄読取",
      "objective": "表題欄から図面メタデータを抽出する",
      "when_to_run": "媒体ルーティング後、シート単位で実行",
      "required_inputs": [
        "sheet_image_or_text",
        "titleblock_region",
        "optional_drawing_index"
      ],
      "knowledge_filters": [
        "シートメタデータ/表題欄",
        "単位・縮尺・方位/解釈"
      ],
      "output_schema": {
        "drawing_no": "string",
        "drawing_title": "string",
        "sheet_scale": "string",
        "revision": "string|null",
        "project_name": "string|null",
        "building_name": "string|null",
        "zone_name": "string|null",
        "discipline": "common|architectural|structural|electrical|mechanical|civil|unknown",
        "confidence": "0-1"
      },
      "system_rules": [
        "表題欄ラベルと値をペアで読む。",
        "図面目録がある場合は番号・名称を照合して正規化する。",
        "不明な値は推定しない。nullで返す。"
      ],
      "failure_conditions": [
        "図面番号・図面名・縮尺のうち2項目以上欠落"
      ],
      "escalation_policy": {
        "route_on_fail": "manual_review",
        "queue": "titleblock_review"
      },
      "prompt_template": "あなたは建設図面の表題欄抽出器です。\n表題欄から図面番号、図面名、縮尺、改訂、工事名、棟名、工区を抽出してください。\n推定は禁止です。読めないものはnullにしてください。\n入力:\n{{input_json}}\n"
    },
    {
      "prompt_id": "PRM_003",
      "prompt_name": "シート分類",
      "objective": "図面のシート種別を分類する",
      "when_to_run": "表題欄読取の直後",
      "required_inputs": [
        "sheet_text",
        "sheet_image",
        "drawing_title",
        "discipline_hint"
      ],
      "knowledge_filters": [
        "建築",
        "構造",
        "電気設備図",
        "機械設備図",
        "土木・道路・造成図"
      ],
      "output_schema": {
        "sheet_type_id": "string",
        "sheet_type_name": "string",
        "discipline": "string",
        "classification_reasons": [
          "string"
        ],
        "confidence": "0-1"
      },
      "system_rules": [
        "図面名、表題欄、図中キーワード、レイアウトの4要素で判断する。",
        "候補が複数ある場合はtop3候補を内部で比較し最終1件を返す。",
        "確信度が低ければunknown系シートに落とす。"
      ],
      "failure_conditions": [
        "候補1位と2位の差が小さい",
        "図面名が一般語のみ"
      ],
      "escalation_policy": {
        "route_on_fail": "manual_review",
        "queue": "sheet_classification_review"
      },
      "prompt_template": "あなたは建設図面のシート分類器です。\n図面を sheet_type_master に基づき1つに分類してください。\n出力はJSONのみ。\n入力:\n{{input_json}}\n"
    },
    {
      "prompt_id": "PRM_004",
      "prompt_name": "単位・縮尺・方位解決",
      "objective": "単位・縮尺・方位・視点方向を解決する",
      "when_to_run": "シート分類後",
      "required_inputs": [
        "sheet_type",
        "discipline",
        "scale_text",
        "north_symbol",
        "notes",
        "dimension_samples"
      ],
      "knowledge_filters": [
        "単位・縮尺・方位/解釈"
      ],
      "output_schema": {
        "length_unit": "mm|m|unknown",
        "elevation_unit": "mm|m|unknown",
        "sheet_scale_ratio": "number|null",
        "view_direction": "top_down|bottom_up|elevation|sectional|profile|cross_section|unknown",
        "reading_order": "left_to_right|top_to_bottom|custom"
      },
      "system_rules": [
        "建築・設備はmm省略を既定、土木はm既定。",
        "天井伏図は見上げ、基礎伏図は見下げとして扱う。",
        "道路縦断は左から右へ測点順に読む。"
      ],
      "failure_conditions": [
        "分野と単位注記が矛盾",
        "縮尺が複数あるのに範囲不明"
      ],
      "escalation_policy": {
        "route_on_fail": "manual_review",
        "queue": "unit_scale_review"
      },
      "prompt_template": "あなたは図面の単位・縮尺・方位解決器です。\n図面種別と注記から、長さ単位、標高単位、縮尺、視点方向、読み順を決定してください。\n入力:\n{{input_json}}\n"
    },
    {
      "prompt_id": "PRM_005",
      "prompt_name": "凡例・略号解決",
      "objective": "凡例・略号・材料コードを正規化する",
      "when_to_run": "シート分類後、実体抽出前に実行",
